{
  "permissions": {
    "deny": [
      "Read(apps/api/.env*)",
      "Edit(apps/api/.env*)",
      "Write(apps/api/.env*)",
      "Read(**/.env)",
      "Edit(**/.env)",
      "Write(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.*.local)",
      "Bash(cat*/.env*)",
      "Bash(*rm -rf*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*DROP TABLE*)",
      "Bash(*TRUNCATE*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}
