  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fiscalYear Int    @map("fiscal_year")
  category   String @db.VarChar(50) /// agent_fee | media_fee | referral_fee
  month      Int    /// 1-12
  budget     Int    @default(0)
  actual     Int    @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([fiscalYear, category, month])
  @@map("recruit_budgets")
}

// ----------------------------------------
// 請求書
// ----------------------------------------
model Invoice {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNo    String    @unique @map("invoice_no") @db.VarChar(30)
  clientId     String    @map("client_id") @db.Uuid
  targetMonth  String    @map("target_month") @db.VarChar(7) /// "2026-04"
  totalAmount  Int       @map("total_amount")
  tax          Int       @default(0)
  invoiceDate  DateTime  @map("invoice_date") @db.Date
  dueDate      DateTime  @map("due_date") @db.Date
  recipientEmail String? @map("recipient_email") @db.VarChar(255)
  status       String    @default("draft") @db.VarChar(20) /// draft | sent | paid | overdue
  paidAt       DateTime? @map("paid_at") @db.Timestamptz
  sentAt       DateTime? @map("sent_at") @db.Timestamptz
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  client       Client    @relation(fields: [clientId], references: [id])
  items        InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId     String @map("invoice_id") @db.Uuid
  employeeName  String @map("employee_name") @db.VarChar(100)
  description   String @db.VarChar(500)
  workHours     Decimal? @map("work_hours") @db.Decimal(5, 1)
  unitPrice     Int    @map("unit_price")
  settlementLower Int? @map("settlement_lower")
  settlementUpper Int? @map("settlement_upper")
  overtimeAmount Int   @default(0) @map("overtime_amount")
  deductionAmount Int  @default(0) @map("deduction_amount")
  subtotal      Int
  sortOrder     Int    @default(0) @map("sort_order")
  employeeId    String?  @map("employee_id") @db.Uuid
  assignmentId  String?  @map("assignment_id") @db.Uuid

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ----------------------------------------
// freee仕訳
// ----------------------------------------
model FreeeJournal {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date        DateTime  @db.Date
  description String    @db.VarChar(300)
  debitAccount  String  @map("debit_account") @db.VarChar(100)
  creditAccount String  @map("credit_account") @db.VarChar(100)
  amount      Int
  status      String    @default("unsent") @db.VarChar(20) /// unsent | sent | error
  sentAt      DateTime? @map("sent_at") @db.Timestamptz
  errorMessage String?  @map("error_message")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("freee_journals")
}

// ----------------------------------------
// シフト計画
// ----------------------------------------
model MonthlyShift {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  yearMonth   String    @map("year_month") @db.VarChar(7)
  isStandard  Boolean   @default(true) @map("is_standard")
  startTime   String?   @map("start_time") @db.VarChar(5)
  customDays  Json?     @map("custom_days")
  confirmedAt DateTime? @map("confirmed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, yearMonth])
  @@map("monthly_shifts")
}

// ----------------------------------------
// J6: 給与レコードの編集履歴
// 管理画面で給与を直接編集した場合、誰がいつ何を変更したかを残す。
// ----------------------------------------
model PayrollEditHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollId   String   @map("payroll_id") @db.Uuid
  editedBy    String?  @map("edited_by") @db.Uuid
  fieldName   String   @map("field_name") @db.VarChar(50)
  oldValue    Int?     @map("old_value")
  newValue    Int?     @map("new_value")
  reason      String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([payrollId, createdAt])
  @@map("payroll_edit_history")
}

// ----------------------------------------
// J1: 料率マスタ（給与計算に使用するデフォルト料率）
// 単一レコードのみ想定（id = 'default'）。
// 社員別の上書きは Employee.rate* フィールドで行う。
// ----------------------------------------
model RateMaster {
  id                      String   @id @default("default") @db.VarChar(20)
  healthInsurance         Decimal  @default(0.05) @map("health_insurance") @db.Decimal(6, 4)
  healthInsuranceStdRate  Decimal  @default(0.0499) @map("health_insurance_std_rate") @db.Decimal(6, 4)
  nursingCareRate         Decimal  @default(0.0080) @map("nursing_care_rate") @db.Decimal(6, 4)
  employeePension         Decimal  @default(0.0915) @map("employee_pension") @db.Decimal(6, 4)
  employmentInsurance     Decimal  @default(0.006) @map("employment_insurance") @db.Decimal(6, 4)
  incomeTax               Decimal  @default(0.033) @map("income_tax") @db.Decimal(6, 4)
  residentTaxFixed        Int      @default(18000) @map("resident_tax_fixed")
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy               String?  @map("updated_by") @db.Uuid

  @@map("rate_master")
}

// ----------------------------------------
// 請求書情報（自社情報）
// シングルレコード（id="default"）。設定ページから編集 → 請求書に反映。
// ----------------------------------------
model CompanyInfo {
  id                 String   @id @default("default") @db.VarChar(20)
  name               String   @default("") @db.VarChar(200)
  postalCode         String   @default("") @map("postal_code") @db.VarChar(20)
  address1           String   @default("") @db.VarChar(300)
  address2           String   @default("") @db.VarChar(300)
  registrationNo     String   @default("") @map("registration_no") @db.VarChar(30)
  bankName           String   @default("") @map("bank_name") @db.VarChar(100)
  bankBranch         String   @default("") @map("bank_branch") @db.VarChar(100)
  bankAccountType    String   @default("普通") @map("bank_account_type") @db.VarChar(20)
  bankAccountNumber  String   @default("") @map("bank_account_number") @db.VarChar(20)
  bankAccountHolder  String   @default("") @map("bank_account_holder") @db.VarChar(100)
  sealImagePath      String?  @map("seal_image_path") @db.VarChar(500)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("company_info")
}

// ----------------------------------------
// 給与テーブル（等級マスタ）
// SES事業部 / 管理部の給与テーブル。社員が選択すると baseSalary / fixedOvertimePay が自動セットされる。
// ----------------------------------------
model SalaryGrade {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  department        String   @db.VarChar(20)          // 'ses' | 'admin'
  grade             Int                                // 等級 or 連番
  overtimeType      Int      @map("overtime_type")     // 固定残業時間: 20 or 40
  grossSalary       Int      @map("gross_salary")      // 総支給額
  baseSalary        Int      @map("base_salary")       // 基本給
  fixedOvertimePay  Int      @map("fixed_overtime_pay") // 固定残業手当
  positionAllowance Int      @default(0) @map("position_allowance") // 役職手当（管理部主任以上）
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  employees Employee[]

  @@unique([department, grade, overtimeType])
  @@map("salary_grades")
}

// ----------------------------------------
// 月次勤怠確定（給与計算ゲート）
// 管理者が月の勤怠を一括確定し、確定後に給与計算を実行可能にする。
// admin（役員）は勤怠免除。
// ----------------------------------------
model AttendanceMonthlyClosure {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  yearMonth             String    @unique @map("year_month") @db.VarChar(7)
  status                String    @default("open") @db.VarChar(20)
  closedAt              DateTime? @map("closed_at") @db.Timestamptz
  closedBy              String?   @map("closed_by") @db.Uuid
  reopenedAt            DateTime? @map("reopened_at") @db.Timestamptz
  reopenedBy            String?   @map("reopened_by") @db.Uuid
  hasPostCloseChanges   Boolean   @default(false) @map("has_post_close_changes")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  closedByEmployee      Employee? @relation("ClosureClosedBy", fields: [closedBy], references: [id])
  reopenedByEmployee    Employee? @relation("ClosureReopenedBy", fields: [reopenedBy], references: [id])

  @@map("attendance_monthly_closures")
}

// ----------------------------------------
// 外部サービス連携トークン（OAuth 2.0）
// ----------------------------------------
model IntegrationToken {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider     String   @unique @db.VarChar(50) // "google_drive"
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  email        String?  @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("integration_tokens")
}
