// ============================================================
// Prisma Schema — SES Portal
// ============================================================
// DBマイグレーション(SQLファイル)で定義したテーブルをPrismaモデルとして定義。
// prisma db pullで既存DBから生成することも可能だが、
// ここでは明示的にモデルを定義して一貫性を保つ。
//
// 注意: マイグレーションはSQL（migrations/）で管理。
// Prisma Migrateは使わず、prisma db pull + prisma generateで同期。
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------
// 部署
// ----------------------------------------
model Department {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(100)
  parentId  String?  @map("parent_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  parent    Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DeptHierarchy")
  employees Employee[]

  @@map("departments")
}

// ----------------------------------------
// 役職
// ----------------------------------------
model Position {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(50)
  rank        Int
  hasApproval Boolean  @default(false) @map("has_approval")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employees Employee[]

  @@map("positions")
}

// ----------------------------------------
// 社員
// ----------------------------------------
model Employee {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeCode      String    @unique @map("employee_code") @db.VarChar(20)
  lastName          String    @map("last_name") @db.VarChar(50)
  firstName         String    @map("first_name") @db.VarChar(50)
  lastNameKana      String    @map("last_name_kana") @db.VarChar(50)
  firstNameKana     String    @map("first_name_kana") @db.VarChar(50)
  birthDate         DateTime  @map("birth_date") @db.Date
  gender            String    @db.VarChar(10)
  hireDate          DateTime  @map("hire_date") @db.Date
  resignDate        DateTime? @map("resign_date") @db.Date
  employmentType    String    @map("employment_type") @db.VarChar(20)
  contractType      String    @default("fixed_term") @map("contract_type") @db.VarChar(20)
  status            String    @default("active") @db.VarChar(20)
  departmentId      String    @map("department_id") @db.Uuid
  positionId        String?   @map("position_id") @db.Uuid
  email             String    @unique @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  address           String?
  postalCode        String?   @map("postal_code") @db.VarChar(10)
  education         String?   @db.VarChar(30)
  schoolName        String?   @map("school_name") @db.VarChar(100)
  baseSalary        Int?      @map("base_salary")
  fixedOvertimePay  Int?      @map("fixed_overtime_pay")
  isExecutive       Boolean   @default(false) @map("is_executive")
  salaryGradeId     String?   @map("salary_grade_id") @db.Uuid
  rewardRate        Decimal?  @map("reward_rate") @db.Decimal(5, 2)
  // J2: 所定労働時間・固定残業時間を社員別に設定（単位: 時間/月、null = デフォルト値を使用）
  contractHours     Int?      @map("contract_hours")
  fixedOvertime     Int?      @map("fixed_overtime")
  // 交通費申請システム: 社員の通勤スタイル（onetime / monthly / three_month / null）
  commuteStyle      String?   @map("commute_style") @db.VarChar(20)
  // L1: 有給付与方式（hire_date = 入社日基準 / transferred = 前職引継ぎ）
  leaveGrantMethod  String?   @map("leave_grant_method") @db.VarChar(20)
  // L1: 前職引継ぎ時の初期残日数（transferred の場合のみ）
  transferredLeaveDays    Decimal?  @map("transferred_leave_days") @db.Decimal(4, 1)
  // L1: 前職での有給付与日（transferred の場合のみ、不明なら入社日をデフォルトとして使う）
  transferredLeaveGrantedDate DateTime? @map("transferred_leave_granted_date") @db.Date
  // J1: 社員別料率上書き（null の場合は RateMaster のデフォルトを使用）
  rateHealthInsurance      Decimal?  @map("rate_health_insurance") @db.Decimal(6, 4)
  rateEmployeePension      Decimal?  @map("rate_employee_pension") @db.Decimal(6, 4)
  rateEmploymentInsurance  Decimal?  @map("rate_employment_insurance") @db.Decimal(6, 4)
  rateIncomeTax            Decimal?  @map("rate_income_tax") @db.Decimal(6, 4)
  rateResidentTaxFixed     Int?      @map("rate_resident_tax_fixed")
  bankName          String?   @map("bank_name") @db.VarChar(100)
  bankBranch        String?   @map("bank_branch") @db.VarChar(100)
  bankAccountType   String?   @map("bank_account_type") @db.VarChar(10)
  bankAccountNumber String?   @map("bank_account_number") @db.VarChar(20)
  bankAccountHolder String?   @map("bank_account_holder") @db.VarChar(100)
  myNumber          String?   @map("my_number")
  hasBonus          Boolean   @default(false) @map("has_bonus")
  station           String?   @db.VarChar(100)
  qualifications    Json?     @default("[]")
  profileImagePath  String?   @map("profile_image_path") @db.VarChar(500)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  department         Department          @relation(fields: [departmentId], references: [id])
  position           Position?           @relation(fields: [positionId], references: [id])
  salaryGrade        SalaryGrade?        @relation(fields: [salaryGradeId], references: [id])
  user               User?
  emergencyContacts  EmergencyContact[]
  dependents         Dependent[]
  assignments        Assignment[]
  attendances        Attendance[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  expenseRequests    ExpenseRequest[]
  changeRequests     ChangeRequest[]
  payrolls           Payroll[]
  notifications      Notification[]
  certificates       Certificate[]
  yearendAdjustments      YearendAdjustment[]
  approvedYearends        YearendAdjustment[] @relation("YearendApprover")
  meetings                Meeting[]
  attendanceCorrections   AttendanceCorrection[]
  approvedCorrections     AttendanceCorrection[] @relation("CorrectionApprover")
  attendanceConfirmed     AttendanceConfirmed[]
  confirmedAttendances    AttendanceConfirmed[]  @relation("ConfirmedBy")
  clientAttendanceUploads ClientAttendanceUpload[]
  delayCertificates       DelayCertificate[]
  confirmedDelayCerts     DelayCertificate[] @relation("DelayCertConfirmer")
  skillsheet              Skillsheet?
  monthlyShifts           MonthlyShift[]
  leaveOfAbsences         LeaveOfAbsence[]
  approvedLoaRequests     LeaveOfAbsence[] @relation("LoaApprover")
  approvedLoaReturns      LeaveOfAbsence[] @relation("LoaReturnApprover")
  closedClosures          AttendanceMonthlyClosure[] @relation("ClosureClosedBy")
  reopenedClosures        AttendanceMonthlyClosure[] @relation("ClosureReopenedBy")
  adminAttendanceEdits    AdminAttendanceEdit[] @relation("AdminEditsEmployee")
  residentTaxes           EmployeeResidentTax[]

  @@map("employees")
}

// ----------------------------------------
// スキルシート
// ----------------------------------------
model Skillsheet {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String   @unique @map("employee_id") @db.Uuid
  employee     Employee @relation(fields: [employeeId], references: [id])
  gender       String?  @db.VarChar(10)
  experience   String?  @db.VarChar(50)
  station      String?  @db.VarChar(100)
  selfPr       String?  @map("self_pr")
  skills       Json?    @default("[]")
  projects     Json?    @default("[]")
  certs        Json?    @default("[]")
  summaryAffiliation   String?  @map("summary_affiliation") @db.VarChar(50)
  summaryMonth         String?  @map("summary_month") @db.VarChar(10)
  summaryRate          String?  @map("summary_rate") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("skillsheets")
}

// ----------------------------------------
// 認証ユーザー
// ----------------------------------------
model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId       String    @unique @map("employee_id") @db.Uuid
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  /// admin | manager | member | employee
  /// 管理側ログイン: admin/manager/member
  /// employee: SES事業部など管理側非ログイン（/mypage のみ）
  role             String    @default("employee") @db.VarChar(20)
  isLocked         Boolean   @default(false) @map("is_locked")
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]
  adminAttendanceEdits AdminAttendanceEdit[] @relation("AdminEditsByUser")

  @@map("users")
}

// ----------------------------------------
// 緊急連絡先
// ----------------------------------------
model EmergencyContact {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String   @map("employee_id") @db.Uuid
  sortOrder    Int      @default(1) @map("sort_order")
  name         String   @db.VarChar(100)
  relationship String   @db.VarChar(30)
  phone        String   @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

// ----------------------------------------
// 扶養家族
// ----------------------------------------
model Dependent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  name         String    @db.VarChar(100)
  relationship String    @db.VarChar(30)
  birthDate    DateTime  @map("birth_date") @db.Date
  annualIncome Int?      @map("annual_income")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("dependents")
}

// ----------------------------------------
// 住民税（特別徴収）月額管理
// 毎年6月〜翌5月の12ヶ月分を fiscalYear + month で管理
// ----------------------------------------
model EmployeeResidentTax {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  fiscalYear  Int      @map("fiscal_year")
  month       Int
  amount      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, fiscalYear, month])
  @@map("employee_resident_taxes")
}

// ----------------------------------------
// クライアント
// ----------------------------------------
model Client {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String    @db.VarChar(200)
  corporateNumber String?   @map("corporate_number") @db.VarChar(30)
  invoiceNumber   String?   @map("invoice_number") @db.VarChar(30)
  postalCode      String?   @map("postal_code") @db.VarChar(10)
  address         String?
  representName   String?   @map("represent_name") @db.VarChar(100)
  establishedDate String?   @map("established_date") @db.VarChar(20)
  capital         String?   @db.VarChar(50)
  websiteUrl      String?   @map("website_url") @db.VarChar(500)
  industry        String?   @db.VarChar(50)
  contactPerson   String?   @map("contact_person") @db.VarChar(100)
  contactEmail    String?   @map("contact_email") @db.VarChar(255)
  contactPhone    String?   @map("contact_phone") @db.VarChar(20)
  tradeFlow       String?   @map("trade_flow") @db.VarChar(50)
  billingEmail    String?   @map("billing_email") @db.VarChar(255)
  tradeStartDate  DateTime? @map("trade_start_date") @db.Date
  freeePartnerId  String?   @map("freee_partner_id") @db.VarChar(50)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  assignments             Assignment[]
  projects                Project[]
  clientAttendanceUploads ClientAttendanceUpload[]
  reconciliationSettings  ReconciliationSettings?
  proposalEmails          ProposalEmail[]
  invoices                Invoice[]

  @@map("clients")
}

// ----------------------------------------
// 案件
// ----------------------------------------
model Project {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId          String    @map("client_id") @db.Uuid
  name              String    @db.VarChar(200)
  contractPrice     Int?      @map("contract_price")
  rewardRate        String?   @map("reward_rate") @db.VarChar(10)
  settlementLower   Int?      @map("settlement_lower")
  settlementUpper   Int?      @map("settlement_upper")
  startDate         DateTime? @map("start_date") @db.Date
  endDate           DateTime? @map("end_date") @db.Date
  workLocation      String?   @map("work_location") @db.VarChar(200)
  area              String?   @db.VarChar(20)
  defaultStartTime  String?   @map("default_start_time") @db.VarChar(5)
  attendanceFormat  String    @default("none") @map("attendance_format") @db.VarChar(20)
  supplyChain       String?   @map("supply_chain") @db.VarChar(20)
  note              String?
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  client      Client       @relation(fields: [clientId], references: [id])
  assignments Assignment[]

  @@map("projects")
}

// ----------------------------------------
// 名刺（商談ログ）
// ----------------------------------------
model BusinessCard {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @db.VarChar(100)
  company    String    @db.VarChar(200)
  department String?   @db.VarChar(200)
  title      String?   @db.VarChar(100)
  email      String?   @db.VarChar(255)
  phone      String?   @db.VarChar(50)
  address    String?
  tag        String?   @db.VarChar(30)
  status     String?   @db.VarChar(30)
  owner      String?   @db.VarChar(100)
  note       String?
  cardImage  String?   @map("card_image") @db.VarChar(500)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  logs       DealLog[]

  @@map("business_cards")
}

model DealLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessCardId String       @map("business_card_id") @db.Uuid
  businessCard   BusinessCard @relation(fields: [businessCardId], references: [id])
  date           DateTime     @db.Date
  content        String
  contacts       String?      /// 商談相手の名前（カンマ区切り）
  cardImages     String?      @map("card_images") /// 名刺画像パスのJSON配列
  recordingUrl   String?      @map("recording_url") @db.VarChar(500)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("deal_logs")
}

// ----------------------------------------
// アサイン（稼働案件）
// ----------------------------------------
model Assignment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId      String    @map("employee_id") @db.Uuid
  clientId        String    @map("client_id") @db.Uuid
  projectId       String?   @map("project_id") @db.Uuid
  projectName     String    @map("project_name") @db.VarChar(200)
  contractPrice   Int       @map("contract_price")
  settlementLower Int       @map("settlement_lower")
  settlementUpper Int       @map("settlement_upper")
  workLocation       String?   @map("work_location") @db.VarChar(200)
  area               String?   @db.VarChar(20)
  defaultStartTime   String?   @map("default_start_time") @db.VarChar(5)
  attendanceFormat          String    @default("none") @map("attendance_format") @db.VarChar(20)
  clientAttendanceRequired  Boolean   @default(true) @map("client_attendance_required")
  startDate                 DateTime  @map("start_date") @db.Date
  endDate            DateTime? @map("end_date") @db.Date
  status             String    @default("active") @db.VarChar(20)
  endReason          String?   @map("end_reason") @db.VarChar(30)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employee     Employee                @relation(fields: [employeeId], references: [id])
  client       Client                  @relation(fields: [clientId], references: [id])
  project      Project?                @relation(fields: [projectId], references: [id])
  rateHistory  AssignmentRateHistory[]

  @@map("assignments")
}

// ----------------------------------------
// アサイン単価改定履歴（M3）
// ----------------------------------------
// contractPrice / settlementLower / settlementUpper の変更を履歴として残す。
// 単価改定を行うたびに1レコード追加する。
// ----------------------------------------
model AssignmentRateHistory {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignmentId       String   @map("assignment_id") @db.Uuid
  effectiveFrom      DateTime @map("effective_from") @db.Date
  contractPrice      Int      @map("contract_price")
  settlementLower    Int      @map("settlement_lower")
  settlementUpper    Int      @map("settlement_upper")
  // 変更理由（任意）
  reason             String?  @db.VarChar(200)
  // 変更実施者
  changedBy          String?  @map("changed_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, effectiveFrom])
  @@map("assignment_rate_history")
}

// ----------------------------------------
// 勤怠
// ----------------------------------------
model Attendance {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId      String    @map("employee_id") @db.Uuid
  workDate        DateTime  @map("work_date") @db.Date
  clockIn         DateTime? @map("clock_in") @db.Timestamptz
  clockOut        DateTime? @map("clock_out") @db.Timestamptz
  breakMinutes    Int       @default(60) @map("break_minutes")
  workMinutes     Int?      @map("work_minutes")
  overtimeMinutes Int?      @map("overtime_minutes")
  status          String    @default("normal") @db.VarChar(20)
  isMissedClock   Boolean   @default(false) @map("is_missed_clock")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employee    Employee               @relation(fields: [employeeId], references: [id])
  corrections AttendanceCorrection[]
  adminEdits  AdminAttendanceEdit[]

  @@unique([employeeId, workDate])
  @@map("attendances")
}

// ----------------------------------------
// 勤怠修正申請
// ----------------------------------------
model AttendanceCorrection {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attendanceId         String    @map("attendance_id") @db.Uuid
  employeeId           String    @map("employee_id") @db.Uuid
  originalClockIn      DateTime? @map("original_clock_in") @db.Timestamptz
  originalClockOut     DateTime? @map("original_clock_out") @db.Timestamptz
  originalBreakMinutes Int?      @map("original_break_minutes")
  newClockIn           DateTime? @map("new_clock_in") @db.Timestamptz
  newClockOut          DateTime? @map("new_clock_out") @db.Timestamptz
  newBreakMinutes      Int?      @map("new_break_minutes")
  reason               String
  status               String    @default("pending") @db.VarChar(20)
  approverId           String?   @map("approver_id") @db.Uuid
  approvedAt           DateTime? @map("approved_at") @db.Timestamptz
  rejectReason         String?   @map("reject_reason")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  attendance Attendance @relation(fields: [attendanceId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])
  approver   Employee?  @relation("CorrectionApprover", fields: [approverId], references: [id])

  @@map("attendance_corrections")
}

// ----------------------------------------
// 管理者による勤怠修正履歴 + 異議申し立て
// ----------------------------------------
model AdminAttendanceEdit {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attendanceId    String    @map("attendance_id") @db.Uuid
  employeeId      String    @map("employee_id") @db.Uuid
  adminUserId     String    @map("admin_user_id") @db.Uuid
  workDate        DateTime  @map("work_date") @db.Date
  oldClockIn      DateTime? @map("old_clock_in") @db.Timestamptz
  oldClockOut     DateTime? @map("old_clock_out") @db.Timestamptz
  oldBreakMinutes Int?      @map("old_break_minutes")
  newClockIn      DateTime? @map("new_clock_in") @db.Timestamptz
  newClockOut     DateTime? @map("new_clock_out") @db.Timestamptz
  newBreakMinutes Int?      @map("new_break_minutes")
  modifiedFields  String[]  @map("modified_fields")
  reason          String
  objectionStatus String    @default("none") @map("objection_status") @db.VarChar(20)
  objectionReason String?   @map("objection_reason")
  objectionAt     DateTime? @map("objection_at") @db.Timestamptz
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  attendance Attendance @relation(fields: [attendanceId], references: [id])
  employee   Employee   @relation("AdminEditsEmployee", fields: [employeeId], references: [id])
  adminUser  User       @relation("AdminEditsByUser", fields: [adminUserId], references: [id])

  @@map("admin_attendance_edits")
}

// ----------------------------------------
// 有給残日数
// ----------------------------------------
model LeaveBalance {
