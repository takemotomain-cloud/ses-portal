# ============================================================
# SES Portal API — 環境変数テンプレート
# ============================================================
# このファイルを .env にコピーして値を設定する
# セキュリティ: .env は .gitignore に含め、絶対にコミットしない
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://ses_dev:ses_dev_password@localhost:5432/ses_portal?schema=public"

# --- JWT ---
# openssl rand -base64 64 で生成した十分な長さのランダム文字列を使用
JWT_SECRET="CHANGE_ME_TO_RANDOM_SECRET_AT_LEAST_64_CHARS"
JWT_EXPIRY="24h"

# --- Application ---
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"

# --- Redis (セッション/キャッシュ) ---
REDIS_URL="redis://localhost:6379"

# --- Encryption (pgcrypto用の対称鍵) ---
# マイナンバー・口座情報等のカラム暗号化に使用
# openssl rand -base64 32 で生成
ENCRYPTION_KEY="CHANGE_ME_TO_RANDOM_KEY"

# --- Mailer (Resend) ---
# 決定事項 S2: メール送信は Resend を使用
# https://resend.com/ で API キーを発行
RESEND_API_KEY=""
MAIL_FROM="株式会社Lervia <sales@lervia.co.jp>"

# --- freee ---
# live 以外では一括送信APIを無効化し、誤って送信済み扱いにしない
FREEE_SYNC_MODE="disabled"

# --- System Admin ---
# テナント管理画面のシークレットキー（URLパラメータ ?key= で使用）
SYSTEM_ADMIN_SECRET="ses-system-2026"

# --- Multi-tenancy ---
# シングルテナント運用時のデフォルトテナントID
SYSTEM_TENANT_ID="00000000-0000-0000-0000-000000000001"
