{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["API_URL", "NEXT_PUBLIC_API_URL"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": ["API_URL", "NEXT_PUBLIC_API_URL"],
      "outputs": [".next/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
