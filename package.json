{
  "name": "ses-portal",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "check:secrets": "node scripts/check-no-secrets.mjs",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "manual:screenshots": "ts-node --project tsconfig.scripts.json scripts/capture-manual-screenshots.ts",
    "manual:build": "ts-node --project tsconfig.scripts.json scripts/build-manual.ts",
    "manual": "pnpm manual:screenshots && pnpm manual:build"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.19.39",
    "markdown-it": "^14.1.1",
    "ts-node": "^10.9.2",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
